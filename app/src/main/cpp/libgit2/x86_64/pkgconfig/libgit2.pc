prefix="/data/data/com.termux/files/usr"
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libgit2
Description: The git library, take 2
Version: 0.28.3

Libs: -L${libdir} -lgit2
Libs.private: -L/data/data/com.termux/files/usr/lib -lssh2
Requires.private: openssl zlib

Cflags: -I${includedir}
